@'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Project specific - DO NOT COMMIT
.refinery/
.refinery_db/
*.db
*.jsonl
*.log
*.tmp
*.temp
image.png

# Test/Debug files
test_*.py
verify_*.py
check_*.py
*_backup.py
*.bak
*.bak2
*.bak3
*_new.py

# Build/output
output/
processors/
scripts/
examples/
src/utils/

# OS
.DS_Store
Thumbs.db

# Dependencies (if using uv)
# uv.lock - actually KEEP this for reproducibility
'@ | Out-File -FilePath ".gitignore" -Encoding UTF8

Write-Host "✅ .gitignore updated!" -ForegroundColor Green