# Make sure .env and data/ are excluded
@'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Project specific - DO NOT COMMIT
.refinery/
.refinery_db/
*.db
*.jsonl
*.log
*.tmp
*.temp
*.png

# Secrets and large files
.env
data/
output/

# Test/Debug files
test_*.py
verify_*.py
check_*.py
*_backup.py
*.bak
*.bak2
*.bak3
*_new.py
'@ | Out-File -FilePath ".gitignore" -Encoding UTF8

# Add updated .gitignore
git add .gitignore

Write-Host "✅ .gitignore updated!" -ForegroundColor Green